---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import CTA from '../components/CTA.astro';
import Footer from '../components/Footer.astro';
import Icon from '../components/Icon.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import DeliveryAreasSlider from '../components/DeliveryAreasSlider.astro';
import { SITE, canonicalUrl } from '../data/site.config';
import { buildSrcset, heroSizes, halfSizes, thirdSizes } from '../utils/images';
---

<Layout
  title={`About Us${SITE.seo.titleSuffix}`}
  description={`Learn about ${SITE.name}. ${SITE.description}`}
  canonical={canonicalUrl("/about/")}
  ogImage={`${SITE.url}/images/placeholder.svg`}
>
  <Header />
  <Breadcrumbs items={[{name: "Home", url: "/"}, {name: "About", url: "/about"}]} />

  <section class="relative min-h-[60vh] flex items-center bg-neutral-900 hero-noise hero-vignette">
    <div class="absolute inset-0 overflow-hidden">
      <img src="/images/placeholder.svg" srcset={buildSrcset("/images/placeholder.svg")} sizes={heroSizes} alt={`About ${SITE.name}`} class="parallax-bg w-full h-full object-cover opacity-40 will-change-transform">
    </div>
    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-24">
      <span data-motion class="inline-block text-brand-400 text-sm font-semibold tracking-widest uppercase mb-6" style="letter-spacing: -0.01em;">About Us</span>
      <h1 class="text-5xl sm:text-6xl lg:text-7xl font-bold text-white leading-none tracking-tight mb-6">
        <span data-animate>Our</span><br/>
        <span data-animate class="text-brand-400">Story</span>
      </h1>
      <p data-animate class="text-xl text-white/80 max-w-2xl leading-relaxed">
        A short tagline about what makes your business unique. What's your mission?
      </p>
    </div>
  </section>

  <section class="py-20 sm:py-24 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <div data-motion class="rounded-3xl overflow-hidden hover-lift">
          <img src="/images/placeholder.svg" alt={`${SITE.name} — our team at ${SITE.business.address.street}`} class="w-full h-[500px] object-cover" loading="lazy" decoding="async" srcset={buildSrcset("/images/placeholder.svg")} sizes={halfSizes} />
        </div>
        <div data-motion>
          <span class="text-brand-600 text-sm font-semibold tracking-wide uppercase mb-4 block" style="letter-spacing: -0.01em;">Who We Are</span>
          <h2 class="text-4xl sm:text-5xl font-bold text-neutral-900 leading-tight mb-6">
            <span data-animate>Your Trusted Partner</span>
          </h2>
          <p data-animate class="text-lg text-neutral-600 mb-6">
            Write your company story. When did you start? What motivated you? 
            What values guide your business? Share what customers appreciate about working with you.
          </p>
          <p data-animate class="text-lg text-neutral-600 mb-8">
            Add more depth — your expertise, your team, your commitment to quality.
            Established in {SITE.business.yearEstablished}, we've been serving 
            {SITE.business.address.locality} for {new Date().getFullYear() - SITE.business.yearEstablished} years.
          </p>
          <div data-motion>
            <a href="/contact" class="hover-shimmer inline-flex items-center gap-2 px-6 py-3 bg-brand-600 hover:bg-brand-700 text-white font-semibold rounded-full transition-colors active:scale-[0.97]">
              Get in Touch
              <Icon name="arrow-right" class="w-4 h-4" />
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <DeliveryAreasSlider />

  <CTA
    badge="Contact Us"
    title="Want to Know More About Us?"
    description="Call or message us. We're happy to answer any questions."
    buttonText={`Call ${SITE.business.contact.phone.display}`}
    buttonLink={`tel:${SITE.business.contact.phone.raw}`}
    image="/images/placeholder.svg"
    altText={`Learn more about ${SITE.name} — call us today`}
  />

  <Footer />
</Layout>
