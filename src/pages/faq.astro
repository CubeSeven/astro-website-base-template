---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Icon from '../components/Icon.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import { SITE, canonicalUrl } from '../data/site.config';
import { faqs, generateFAQSchema } from '../data/content/faq';
import { buildSrcset, heroSizes } from '../utils/images';

const faqSchema = generateFAQSchema();
---

<Layout
  title={`FAQ${SITE.seo.titleSuffix}`}
  description="Frequently asked questions about our services, hours, and policies."
  canonical={canonicalUrl("/faq/")}
>
  <Header />
  <Breadcrumbs items={[{name: "Home", url: "/"}, {name: "FAQ", url: "/faq"}]} />

  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)}></script>

  <section class="relative min-h-[50vh] flex items-center bg-neutral-900 hero-noise hero-vignette">
    <div class="absolute inset-0 overflow-hidden">
      <img src="/images/placeholder.svg" srcset={buildSrcset("/images/placeholder.svg")} sizes={heroSizes} alt="Frequently Asked Questions" class="parallax-bg w-full h-full object-cover opacity-40 scale-110 will-change-transform">
    </div>
    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-24">
      <span data-motion class="inline-block text-brand-400 text-sm font-semibold tracking-widest uppercase mb-6" style="letter-spacing: -0.01em;">Help Center</span>
      <h1 class="text-5xl sm:text-6xl lg:text-7xl font-bold text-white leading-none">
        <span data-animate>Frequently Asked</span><br/>
        <span data-animate class="text-brand-400">Questions</span>
      </h1>
      <p data-animate class="text-xl text-white/80 max-w-2xl leading-relaxed mt-6">
        Find answers to common questions. Can't find what you're looking for? Contact us directly.
      </p>
    </div>
  </section>

  <!-- FAQ Accordion -->
  <section class="py-20 sm:py-24 bg-white">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex flex-col gap-4">
        {faqs.map((faq, i) => (
          <div data-motion style={`--motion-delay:${i * 60}ms`} class="faq-item bg-white border border-neutral-200 rounded-2xl p-6 cursor-pointer hover:border-brand-400 transition-all duration-300">
            <div class="flex items-start justify-between gap-4" onclick={`this.closest('.faq-item').classList.toggle('open'); this.closest('.faq-item').querySelector('.faq-accordion').classList.toggle('open'); this.querySelector('svg').classList.toggle('rotate-180')`}>
              <h3 class="text-lg font-semibold text-neutral-900 pr-4">{faq.q}</h3>
              <svg class="w-5 h-5 text-neutral-400 shrink-0 mt-1 transition-transform duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
            </div>
            <div class="faq-accordion mt-2">
              <div class="faq-accordion-inner">
                <div class="faq-accent h-full absolute left-0 top-0 w-0 bg-brand-500 rounded-l-2xl"></div>
                <p class="text-neutral-600 pt-3">{faq.a}</p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <div class="py-16 bg-neutral-50">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <p class="text-lg text-neutral-600 mb-8">Still have questions? We're available during business hours.</p>
      <div class="flex flex-wrap gap-4 justify-center">
        <a href={`tel:${SITE.business.contact.phone.raw}`} class="hover-shimmer active:scale-[0.97] inline-flex items-center gap-2 px-8 py-4 bg-brand-600 hover:bg-brand-700 text-white font-semibold rounded-full transition-colors">
          <Icon name="phone" class="w-5 h-5" />
          Call {SITE.business.contact.phone.display}
        </a>
        <a href={SITE.business.contact.whatsappUrl} target="_blank" class="hover-shimmer active:scale-[0.97] inline-flex items-center gap-2 px-8 py-4 bg-green-600 hover:bg-green-700 text-white font-semibold rounded-full transition-colors">
          <Icon name="whatsapp" class="w-5 h-5" />
          WhatsApp
        </a>
      </div>
    </div>
  </div>

  <Footer />
</Layout>
