---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import CTA from '../components/CTA.astro';
import Footer from '../components/Footer.astro';
import Icon from '../components/Icon.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import { SITE, canonicalUrl } from '../data/site.config';
import { seafoodCategories } from '../data/content/seafood-categories';
import { buildSrcset, heroSizes, halfSizes } from '../utils/images';
---

<Layout
  title="Fresh Aegean Seafood Categories - Retail | Skiathos Fish Market"
  description="Fresh retail seafood in Skiathos Town. Wild-caught Aegean white fish, cephalopods, shellfish, crustaceans, and deep-sea catch. Professional fishmonger preparation available."
  canonical={canonicalUrl("/fresh-seafood/")}
  ogImage={`${SITE.url}/images/skiathos-hero-seafood.webp`}
>
  <Header />
  <Breadcrumbs items={[{name: "Home", url: "/"}, {name: "Fresh Seafood", url: "/fresh-seafood"}]} />

  <!-- Product/ItemList Schema -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "ItemList",
    "itemListElement": seafoodCategories.map(cat => ({
      "@type": "ListItem",
      "position": cat.position,
      "name": cat.name,
      "description": cat.description,
    }))
  })}></script>

  <section class="relative min-h-[60vh] flex items-center bg-neutral-900 hero-noise hero-vignette">
    <div class="absolute inset-0 overflow-hidden">
      <img src="/images/skiathos-hero-seafood.webp" srcset={buildSrcset("/images/skiathos-hero-seafood.webp")} sizes={heroSizes} alt="Aegean seafood display counter at Skiathos Fish Market in Skiathos Town" class="parallax-bg w-full h-full object-cover opacity-40 scale-110 will-change-transform">
    </div>
    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-24">
      <span data-motion class="inline-block text-brand-400 text-sm font-semibold tracking-widest uppercase mb-6" style="letter-spacing: -0.01em;">Retail Selection</span>
      <h1 class="text-5xl sm:text-6xl lg:text-7xl font-bold text-white leading-none tracking-tight mb-6" style="text-shadow: 0 0 40px rgba(74,127,157,0.08);">
        <span data-animate>Fresh Aegean</span><br/>
        <span data-animate class="text-brand-400">Seafood Categories</span>
      </h1>
       <p data-animate class="text-xl text-white/80 max-w-2xl leading-relaxed">
          Wild-caught from the Aegean Sea, picked fresh every day by our fishmongers in Skiathos Town. From everyday grilling staples to live seafood for the best tables across the Northern Sporades.
        </p>
    </div>
  </section>

  <!-- Category 1: White Fish -->
  <section class="py-20 sm:py-24 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <div data-motion class="rounded-3xl overflow-hidden hover-lift order-2 lg:order-1">
          <img src="/images/skiathos-fish-04.webp" srcset={buildSrcset("/images/skiathos-fish-04.webp")} sizes={halfSizes} alt="Daily wild-caught premium white fish category from Aegean Sea at Skiathos Fish Market" class="w-full h-[400px] object-cover" loading="lazy" decoding="async" />
        </div>
        <div class="order-1 lg:order-2">
          <span data-motion class="text-brand-600 text-sm font-semibold tracking-wide uppercase mb-4 block" style="letter-spacing: -0.01em;">Category 01</span>
          <h2 data-animate class="text-4xl sm:text-5xl font-bold text-neutral-900 leading-tight mb-6" style="text-shadow: 0 0 40px rgba(74,127,157,0.08);">White Fish</h2>
          <p data-animate class="text-lg text-neutral-600 mb-6">
            Our daily selection of wild-caught white fish, bought directly from Aegean fishing boats
            working the waters around Skiathos. Every fish is hand-selected for freshness, firmness, and
            cooking quality.
          </p>
          <p data-animate class="text-neutral-600 mb-8">
            Ideal for charcoal grilling, baking with herbs and olive oil, or pan-searing. Light, flaky, and caught from local waters.
          </p>
          <div data-motion class="flex flex-wrap gap-3">
            <span class="inline-flex items-center gap-1.5 px-3 py-1.5 tag-pill text-brand-700 text-sm font-medium rounded-full" style="--motion-delay:0ms">
              <Icon name="check" class="w-4 h-4" />
              Daily Wild-Caught
            </span>
            <span class="inline-flex items-center gap-1.5 px-3 py-1.5 tag-pill text-brand-700 text-sm font-medium rounded-full" style="--motion-delay:100ms">
              <Icon name="check" class="w-4 h-4" />
              Grill-Ready
            </span>
            <span class="inline-flex items-center gap-1.5 px-3 py-1.5 tag-pill text-brand-700 text-sm font-medium rounded-full" style="--motion-delay:200ms">
              <Icon name="check" class="w-4 h-4" />
              Baking Selection
            </span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Category 2: Cephalopods -->
  <section class="py-20 sm:py-24 bg-neutral-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <div>
          <span data-motion class="text-brand-600 text-sm font-semibold tracking-wide uppercase mb-4 block" style="letter-spacing: -0.01em;">Category 02</span>
          <h2 data-animate class="text-4xl sm:text-5xl font-bold text-neutral-900 leading-tight mb-6" style="text-shadow: 0 0 40px rgba(74,127,157,0.08);">Cephalopods & Invertebrates</h2>
          <p data-animate class="text-lg text-neutral-600 mb-6">
            Local octopus, squid, and cuttlefish caught in the traditional waters around Skiathos and
            the Northern Sporades. Essential to Greek island cooking. From sun-dried
            preparations to classic fried delicacies.
          </p>
          <p data-animate class="text-neutral-600 mb-8">
            We prepare these for a range of traditional cooking methods: boiling for
            tender salads, flash-frying for crispy appetizers, slow-braising for stews, and sun-drying
            that concentrates flavor for the beloved "htapodi sti schara" texture.
          </p>
          <div data-motion class="flex flex-wrap gap-3">
            <span class="inline-flex items-center gap-1.5 px-3 py-1.5 tag-pill-light text-brand-700 text-sm font-medium rounded-full shadow-sm" style="--motion-delay:0ms">
              <Icon name="check" class="w-4 h-4" />
              Sun-Drying Ready
            </span>
            <span class="inline-flex items-center gap-1.5 px-3 py-1.5 tag-pill-light text-brand-700 text-sm font-medium rounded-full shadow-sm" style="--motion-delay:100ms">
              <Icon name="check" class="w-4 h-4" />
              Boiling Selection
            </span>
            <span class="inline-flex items-center gap-1.5 px-3 py-1.5 tag-pill-light text-brand-700 text-sm font-medium rounded-full shadow-sm" style="--motion-delay:200ms">
              <Icon name="check" class="w-4 h-4" />
              Flash-Fry Prep
            </span>
          </div>
        </div>
        <div data-motion class="rounded-3xl overflow-hidden hover-lift">
          <img src="/images/skiathos-fish-07.webp" srcset={buildSrcset("/images/skiathos-fish-07.webp")} sizes={halfSizes} alt="Fresh cephalopods and invertebrates selection for traditional Greek cooking in Skiathos" class="w-full h-[400px] object-cover" loading="lazy" decoding="async" />
        </div>
      </div>
    </div>
  </section>

  <!-- Category 3: Shellfish & Crustaceans -->
  <section class="py-20 sm:py-24 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <div data-motion class="rounded-3xl overflow-hidden hover-lift order-2 lg:order-1">
          <img src="/images/skiathos-fish-02.webp" srcset={buildSrcset("/images/skiathos-fish-02.webp")} sizes={halfSizes} alt="Live shellfish and crustaceans for sea-to-table dining in Skiathos" class="w-full h-[400px] object-cover" loading="lazy" decoding="async" />
        </div>
        <div class="order-1 lg:order-2">
          <span data-motion class="text-brand-600 text-sm font-semibold tracking-wide uppercase mb-4 block" style="letter-spacing: -0.01em;">Category 03</span>
          <h2 data-animate class="text-4xl sm:text-5xl font-bold text-neutral-900 leading-tight mb-6" style="text-shadow: 0 0 40px rgba(74,127,157,0.08);">Shellfish & Crustaceans</h2>
          <p data-animate class="text-lg text-neutral-600 mb-6">
            Live shellfish and crustaceans straight to your table.
            Bought from local fisheries and kept fresh until you take them home.
          </p>
          <p data-animate class="text-neutral-600 mb-8">
            Aegean seafood for restaurants and private dining. We keep live selections in top shape,
            and our flash-frozen options hold their flavor for planned events and yacht provisioning.
          </p>
          <div data-motion class="flex flex-wrap gap-3">
            <span class="inline-flex items-center gap-1.5 px-3 py-1.5 tag-pill text-brand-700 text-sm font-medium rounded-full" style="--motion-delay:0ms">
              <Icon name="check" class="w-4 h-4" />
              Live Selections
            </span>
            <span class="inline-flex items-center gap-1.5 px-3 py-1.5 tag-pill text-brand-700 text-sm font-medium rounded-full" style="--motion-delay:100ms">
              <Icon name="check" class="w-4 h-4" />
              Upscale Dining
            </span>
            <span class="inline-flex items-center gap-1.5 px-3 py-1.5 tag-pill text-brand-700 text-sm font-medium rounded-full" style="--motion-delay:200ms">
              <Icon name="check" class="w-4 h-4" />
              Sea-to-Table
            </span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Category 4: Deep-Sea Wild Catch -->
  <section class="py-20 sm:py-24 bg-neutral-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <div>
          <span data-motion class="text-brand-600 text-sm font-semibold tracking-wide uppercase mb-4 block" style="letter-spacing: -0.01em;">Category 04</span>
          <h2 data-animate class="text-4xl sm:text-5xl font-bold text-neutral-900 leading-tight mb-6" style="text-shadow: 0 0 40px rgba(74,127,157,0.08);">Deep-Sea Wild Catch</h2>
          <p data-animate class="text-lg text-neutral-600 mb-6">
            Large deep-sea fish for special occasions and family feasts.
            These are the fish at the heart of Greek island hospitality.
          </p>
          <p data-animate class="text-neutral-600 mb-8">
            Great for special occasions, restaurant service, and yacht provisioning.
          </p>
          <p data-animate class="text-neutral-600 mb-8">
            Reserved for special occasions, high-end restaurant service,
            and luxury yacht provisioning. Each fish is selected for size, condition, and
            versatility. Suitable for whole roasting, salt-crust baking, or traditional "psari sta karvouna"
            over open charcoal.
          </p>
          <div data-motion class="flex flex-wrap gap-3">
            <span class="inline-flex items-center gap-1.5 px-3 py-1.5 tag-pill-light text-brand-700 text-sm font-medium rounded-full shadow-sm" style="--motion-delay:0ms">
              <Icon name="check" class="w-4 h-4" />
              Centerpiece Presentations
            </span>
            <span class="inline-flex items-center gap-1.5 px-3 py-1.5 tag-pill-light text-brand-700 text-sm font-medium rounded-full shadow-sm" style="--motion-delay:100ms">
              <Icon name="check" class="w-4 h-4" />
              Whole Roasting
            </span>
            <span class="inline-flex items-center gap-1.5 px-3 py-1.5 tag-pill-light text-brand-700 text-sm font-medium rounded-full shadow-sm" style="--motion-delay:200ms">
              <Icon name="check" class="w-4 h-4" />
              Luxury Provisioning
            </span>
          </div>
        </div>
        <div data-motion class="rounded-3xl overflow-hidden hover-lift">
          <img src="/images/skiathos-fish-06.webp" srcset={buildSrcset("/images/skiathos-fish-06.webp")} sizes={halfSizes} alt="Large-format deep-sea wild catch specimens for luxury yacht provisioning and centerpiece presentations" class="w-full h-[400px] object-cover" loading="lazy" decoding="async" />
        </div>
      </div>
    </div>
  </section>

  <!-- Local Context -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div data-motion class="text-center max-w-3xl mx-auto mb-12">
        <span class="text-brand-600 text-sm font-semibold tracking-wide uppercase mb-4 block" style="letter-spacing: -0.01em;">Local Sourcing</span>
        <h2 class="text-3xl sm:text-4xl font-bold text-neutral-900 leading-tight" data-animate style="text-shadow: 0 0 40px rgba(74,127,157,0.08);">Directly from Aegean Waters Around Skiathos</h2>
      </div>
      <div class="grid md:grid-cols-3 gap-8 max-w-4xl mx-auto text-center">
        <div data-motion style="--motion-delay:0ms">
          <div class="text-4xl font-bold text-brand-600 mb-2 icon-container">Daily</div>
          <p class="text-neutral-600">Fresh catch arrives from local fishing vessels operating in the Northern Sporades</p>
        </div>
        <div data-motion style="--motion-delay:100ms">
          <div class="text-4xl font-bold text-brand-600 mb-2 icon-container">100%</div>
          <p class="text-neutral-600">Flash-frozen at peak freshness</p>
        </div>
        <div data-motion style="--motion-delay:200ms">
          <div class="text-4xl font-bold text-brand-600 mb-2 icon-container">Hand-Selected</div>
          <p class="text-neutral-600">Hand-selected by our fishmongers for firmness, freshness, and readiness to cook</p>
        </div>
      </div>
    </div>
  </section>

  <CTA
    badge="Visit Our Market"
    title="Order Your Fresh Aegean Seafood Today"
    description="Visit us at 48 Ethnikis Antistaseos in Skiathos Town, or call ahead for availability."
    buttonText="Call 693 115 6528"
    buttonLink="tel:6931156528"
    image="/images/skiathos-hero-seafood.webp"
    altText="Fresh Aegean seafood counter at Skiathos Fish Market, 48 Ethnikis Antistaseos, Skiathos Town"
  />

  <Footer />
</Layout>
