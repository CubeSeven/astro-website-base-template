---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import CTA from '../../components/CTA.astro';
import Footer from '../../components/Footer.astro';
import { SITE, canonicalUrl } from '../../data/site.config';
import { blogPosts } from '../../data/content/blog';
import { buildSrcset, halfSizes } from '../../utils/images';

export function getStaticPaths() {
  return blogPosts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const pageUrl = `${SITE.blog.path}/${post.slug}`;
---

<Layout
  title={`${post.title}${SITE.seo.titleSuffix}`}
  description={post.excerpt}
  canonical={canonicalUrl(pageUrl)}
  ogImage={`${SITE.url}${post.image}`}
>
  <Header />
  <Breadcrumbs items={[
    { name: "Home", url: "/" },
    { name: SITE.blog.title, url: SITE.blog.path },
    { name: post.title, url: pageUrl },
  ]} />

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BlogPosting",
    headline: post.title,
    description: post.excerpt,
    image: `${SITE.url}${post.image}`,
    datePublished: post.date,
    dateModified: post.date,
    author: {
      "@type": "Person",
      name: post.author,
    },
    publisher: {
      "@type": "Organization",
      name: SITE.business.legalName,
      logo: {
        "@type": "ImageObject",
        url: `${SITE.url}${SITE.logoPath}`,
      },
    },
    mainEntityOfPage: {
      "@type": "WebPage",
      "@id": `${SITE.url}${pageUrl}`,
    },
  })}></script>


  <!-- Hero -->
  <section class="relative min-h-[50vh] flex items-end bg-neutral-900 hero-noise hero-vignette">
    <div class="absolute inset-0 overflow-hidden">
      <img
        src={post.image}
        srcset={buildSrcset(post.image)}
        sizes={halfSizes}
        alt={post.alt}
        class="w-full h-full object-cover opacity-50"
      />
    </div>
    <div class="relative z-10 max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-24 w-full">
      <div class="flex flex-wrap items-center gap-3 text-sm text-white/60 mb-4">
        <time datetime={post.date}>{new Date(post.date).toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" })}</time>
        {post.category && (
          <>
            <span class="w-1 h-1 bg-white/40 rounded-full"></span>
            <span>{post.category}</span>
          </>
        )}
        {post.readingTime && (
          <>
            <span class="w-1 h-1 bg-white/40 rounded-full"></span>
            <span>{post.readingTime} min read</span>
          </>
        )}
      </div>
      <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold text-white leading-tight">{post.title}</h1>
      <p class="mt-4 text-lg text-white/70 max-w-2xl">{post.excerpt}</p>
    </div>
  </section>

  <!-- Content -->
  <article class="py-16 bg-white">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="prose">
        <Fragment set:html={post.content} />
      </div>

      <!-- Tags -->
      {post.tags.length > 0 && (
        <div class="flex flex-wrap gap-2 mt-12 pt-8 border-t border-neutral-200">
          {post.tags.map((tag) => (
            <span class="px-3 py-1.5 bg-neutral-100 text-neutral-600 text-sm rounded-full tag-pill">
              #{tag}
            </span>
          ))}
        </div>
      )}

      <!-- Author -->
      {post.author && (
        <div class="flex items-center gap-4 mt-8 p-6 bg-neutral-50 rounded-2xl">
          <div class="w-12 h-12 bg-brand-100 rounded-full flex items-center justify-center text-brand-600 font-bold text-lg">
            {post.author.charAt(0)}
          </div>
          <div>
            <p class="font-semibold text-neutral-900">{post.author}</p>
            <p class="text-sm text-neutral-500">Author</p>
          </div>
        </div>
      )}
    </div>
  </article>

  <CTA
    badge="Get in Touch"
    title="Have Questions?"
    description="We're here to help. Contact us anytime."
    buttonText={`Call ${SITE.business.contact.phone.display}`}
    buttonLink={`tel:${SITE.business.contact.phone.raw}`}
    image="/images/placeholder.svg"
    altText={`Contact ${SITE.name}`}
  />

  <Footer />
</Layout>
