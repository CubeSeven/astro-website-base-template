---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import CTA from '../components/CTA.astro';
import Footer from '../components/Footer.astro';
import Icon from '../components/Icon.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import { canonicalUrl } from '../data/site.config';
import { buildSrcset, heroSizes, halfSizes } from '../utils/images';
---

<Layout
  title="Traditional & Seasonal Seafood Categories | Skiathos Fish Market"
  description="Traditional desalted cod, Lenten seafood, and seasonal specialties for Clean Monday, Holy Week, and Greek Orthodox holidays. Prepared in-house in Skiathos Town."
  canonical={canonicalUrl("/traditional-seasonal/")}
>
  <Header />
  <Breadcrumbs items={[{name: "Home", url: "/"}, {name: "Traditional & Seasonal", url: "/traditional-seasonal"}]} />

  <section class="relative min-h-[60vh] flex items-center bg-neutral-900 hero-noise hero-vignette">
    <div class="absolute inset-0 overflow-hidden">
      <img src="/images/skiathos-fish-08.webp" alt="Traditional Greek seafood preparation at Skiathos Fish Market for Clean Monday and Holy Week" class="parallax-bg w-full h-full object-cover opacity-40 scale-110 will-change-transform" srcset={buildSrcset("/images/skiathos-fish-08.webp")} sizes={heroSizes}>
    </div>
    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-24">
      <span data-motion class="inline-block text-brand-400 text-sm font-semibold tracking-widest uppercase mb-6" style="letter-spacing: -0.01em;">Seasonal & Traditional</span>
      <h1 class="text-5xl sm:text-6xl lg:text-7xl font-bold text-white leading-none tracking-tight mb-6" style="text-shadow: 0 0 40px rgba(74,127,157,0.08);">
        <span data-animate>Traditional &</span><br/>
        <span data-animate class="text-brand-400">Seasonal Categories</span>
      </h1>
      <p data-animate class="text-xl text-white/80 max-w-2xl leading-relaxed">
        Following the Greek culinary calendar in Skiathos Town. Desalted cod, Lenten
        seafood, and seasonal specialties prepared the traditional way by our fishmongers.
      </p>
    </div>
  </section>

  <!-- Desalted Category -->
  <section class="py-20 sm:py-24 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <div data-motion class="rounded-3xl overflow-hidden order-2 lg:order-1 hover-lift">
          <img src="/images/skiathos-fish-03.webp" alt="Artisanal desalted cod preparation process at Skiathos Fish Market for Greek Easter" class="w-full h-[450px] object-cover" loading="lazy" decoding="async" srcset={buildSrcset("/images/skiathos-fish-03.webp")} sizes={halfSizes} />
        </div>
        <div class="order-1 lg:order-2">
          <span data-motion class="text-brand-600 text-sm font-semibold tracking-wide uppercase mb-4 block" style="letter-spacing: -0.01em;">Traditional Preparation</span>
          <h2 data-animate class="text-4xl sm:text-5xl font-bold text-neutral-900 leading-tight mb-6" style="text-shadow: 0 0 40px rgba(74,127,157,0.08);">Traditional Desalted Selections</h2>
          <p data-animate class="text-lg text-neutral-600 mb-6">
            Our desalted cod and preserved seafood are prepared in-house the traditional way,
            restoring natural texture and flavor. The foundation of
            Greek "bakaliaros" dishes, done the way it has always been done.
          </p>
          <p data-animate class="text-neutral-600 mb-8">
            Desalting takes care: the right number of water changes, steady temperature, and
            proper timing. Our fishmongers have been doing it for over 20 years.
            We prepare cod for Greek Easter and winter meals for families across the
            Northern Sporades.
          </p>
          <div data-motion class="grid sm:grid-cols-2 gap-4">
            <div class="flex items-start gap-3">
              <Icon name="check" class="w-5 h-5 text-brand-500 shrink-0 mt-0.5" />
              <span class="text-neutral-700">In-house desalting</span>
            </div>
            <div class="flex items-start gap-3">
              <Icon name="check" class="w-5 h-5 text-brand-500 shrink-0 mt-0.5" />
              <span class="text-neutral-700">Texture preservation</span>
            </div>
            <div class="flex items-start gap-3">
              <Icon name="check" class="w-5 h-5 text-brand-500 shrink-0 mt-0.5" />
              <span class="text-neutral-700">Traditional flavor balance</span>
            </div>
            <div class="flex items-start gap-3">
              <Icon name="check" class="w-5 h-5 text-brand-500 shrink-0 mt-0.5" />
              <span class="text-neutral-700">Bulk holiday orders</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Lenten Category -->
  <section class="py-20 sm:py-24 bg-neutral-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <div>
          <span data-motion class="text-brand-600 text-sm font-semibold tracking-wide uppercase mb-4 block" style="letter-spacing: -0.01em;">Holiday Preparation</span>
          <h2 data-animate class="text-4xl sm:text-5xl font-bold text-neutral-900 leading-tight mb-6" style="text-shadow: 0 0 40px rgba(74,127,157,0.08);">Lenten Selections</h2>
          <p data-animate class="text-lg text-neutral-600 mb-6">
            Fasting-approved seafood for Clean Monday, Holy Week, and the
            entire Lenten period. We scale up our stock for these
            major Greek Orthodox observances.
          </p>
          <p data-animate class="text-neutral-600 mb-8">
            During Clean Monday (Καθαρά Δευτέρα) and Holy Week, we supply a wide range of
            shellfish, invertebrates, cephalopods, and preserved specialties from the Aegean Sea. From
            family gatherings to church community events across the island, you can get what you need without
            compromising on quality during the fasting period.
          </p>
          <div data-motion class="grid sm:grid-cols-2 gap-4">
            <div class="flex items-start gap-3">
              <Icon name="check" class="w-5 h-5 text-brand-500 shrink-0 mt-0.5" />
              <span class="text-neutral-700">Clean Monday bulk stock</span>
            </div>
            <div class="flex items-start gap-3">
              <Icon name="check" class="w-5 h-5 text-brand-500 shrink-0 mt-0.5" />
              <span class="text-neutral-700">Holy Week supply</span>
            </div>
            <div class="flex items-start gap-3">
              <Icon name="check" class="w-5 h-5 text-brand-500 shrink-0 mt-0.5" />
              <span class="text-neutral-700">Fasting-approved categories</span>
            </div>
            <div class="flex items-start gap-3">
              <Icon name="check" class="w-5 h-5 text-brand-500 shrink-0 mt-0.5" />
              <span class="text-neutral-700">Community event orders</span>
            </div>
          </div>
        </div>
        <div data-motion class="rounded-3xl overflow-hidden hover-lift">
          <img src="/images/skiathos-fish-09.webp" alt="Fasting-approved Lenten seafood selections for Clean Monday and Holy Week in Skiathos" class="w-full h-[450px] object-cover" loading="lazy" decoding="async" srcset={buildSrcset("/images/skiathos-fish-09.webp")} sizes={halfSizes} />
        </div>
      </div>
    </div>
  </section>

  <!-- Seasonal Calendar -->
  <section class="py-20 sm:py-24 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div data-motion class="text-center max-w-3xl mx-auto mb-16">
        <span class="text-brand-600 text-sm font-semibold tracking-wide uppercase mb-4 block" style="letter-spacing: -0.01em;">Greek Culinary Calendar</span>
        <h2 class="text-4xl sm:text-5xl font-bold text-neutral-900 leading-tight" data-animate style="text-shadow: 0 0 40px rgba(74,127,157,0.08);">Peak Seasons We Serve</h2>
      </div>

      <div class="grid md:grid-cols-3 gap-8">
        <div data-motion class="p-8 bg-neutral-50 rounded-3xl hover-border-draw" style="--motion-delay:0ms">
          <div class="w-14 h-14 bg-white rounded-2xl flex items-center justify-center mb-6 shadow-sm icon-container">
            <Icon name="calendar" class="w-7 h-7 text-brand-600" />
          </div>
          <h3 class="text-2xl font-bold text-neutral-900 mb-3">Clean Monday</h3>
          <p class="text-sm text-brand-600 font-semibold mb-2">February / March</p>
          <p class="text-neutral-600">The start of Lent. We stock up on shellfish, invertebrates, and preserved seafood for the traditional outdoor kite-flying feasts.</p>
        </div>
        <div data-motion class="p-8 bg-neutral-50 rounded-3xl hover-border-draw" style="--motion-delay:100ms">
          <div class="w-14 h-14 bg-white rounded-2xl flex items-center justify-center mb-6 shadow-sm icon-container">
            <Icon name="clock" class="w-7 h-7 text-brand-600" />
          </div>
          <h3 class="text-2xl font-bold text-neutral-900 mb-3">Holy Week</h3>
          <p class="text-sm text-brand-600 font-semibold mb-2">April</p>
          <p class="text-neutral-600">The busiest period on the Greek Orthodox calendar. We prepare desalted cod, shellfish, and fasting selections at peak volume for families and churches.</p>
        </div>
        <div data-motion class="p-8 bg-neutral-50 rounded-3xl hover-border-draw" style="--motion-delay:200ms">
          <div class="w-14 h-14 bg-white rounded-2xl flex items-center justify-center mb-6 shadow-sm icon-container">
            <Icon name="globe" class="w-7 h-7 text-brand-600" />
          </div>
          <h3 class="text-2xl font-bold text-neutral-900 mb-3">Summer Peak</h3>
          <p class="text-sm text-brand-600 font-semibold mb-2">June – September</p>
          <p class="text-neutral-600">Tourist season brings peak demand from villas, yachts, and restaurants across Skiathos. Our wholesale operation runs at full capacity to serve the island with the best Aegean seafood.</p>
        </div>
      </div>
    </div>
  </section>

  <CTA
    badge="Plan Ahead"
    title="Reserve Your Holiday Seafood Order"
    description="Plan ahead for seasonal holidays and traditional Greek cooking. Call or WhatsApp to reserve your order."
    buttonText="Call 693 115 6528"
    buttonLink="tel:6931156528"
    image="/images/skiathos-fish-08.webp"
    altText="Traditional seasonal seafood for Greek holidays and Lenten feasts at Skiathos Fish Market"
  />

  <Footer />
</Layout>
