---
const { items } = Astro.props;
---

<section class="py-20 sm:py-24 bg-neutral-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div data-motion class="text-center mb-16">
      <span class="text-brand-600 text-sm font-semibold tracking-wide uppercase mb-3 block">Testimonials</span>
      <h2 class="text-4xl sm:text-5xl font-bold text-neutral-900">
        <span data-animate>What Our Customers Say</span>
      </h2>
    </div>

    <div class="grid md:grid-cols-3 gap-6">
      {items.map((item) => (
        <div data-motion class="p-8 rounded-3xl bg-white flex flex-col gap-6">
          <div class="flex gap-1">
            {[...Array(5)].map(() => (
              <svg class="w-5 h-5 text-yellow-400" fill="currentColor" viewBox="0 0 20 20">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
              </svg>
            ))}
          </div>
          <p class="text-neutral-600 leading-relaxed flex-1">"{item.quote}"</p>
          <div class="flex items-center gap-3 pt-4 border-t border-neutral-100">
            <img src={item.avatar} alt={item.name} class="w-10 h-10 rounded-full object-cover" />
            <div>
              <p class="text-sm font-semibold text-neutral-900">{item.name}</p>
              <p class="text-xs text-neutral-500">{item.role}</p>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
