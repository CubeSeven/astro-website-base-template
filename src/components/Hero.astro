---
import Icon from './Icon.astro';
import { SITE } from '../data/site.config';
import { buildSrcset, heroSizes } from '../utils/images';

const { title, subtitle, ctaText, ctaLink, secondaryText, secondaryLink, image, altText } = Astro.props;

const heroSrcset = buildSrcset(image);
const heroAlt = altText || `Fresh seafood at ${SITE.name}, ${SITE.business.address.street}, ${SITE.business.address.locality}`;
---

<section class="hero-cursor-glow hero-noise hero-vignette relative min-h-screen flex items-center">
  <!-- Full Background Image -->
  <div class="absolute inset-0 overflow-hidden">
    <img
      src={image}
      srcset={heroSrcset}
      sizes={heroSizes}
      alt={heroAlt}
      class="parallax-bg w-full h-full object-cover scale-110 will-change-transform"
      fetchpriority="high"
    >
    <div class="absolute inset-0 bg-gradient-to-r from-neutral-900/95 via-neutral-900/70 to-transparent"></div>
  </div>

  <!-- Content -->
  <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 min-h-screen flex items-center w-full">
    <div class="max-w-2xl py-20">
      <!-- Google Reviews Badge -->
      <div data-motion class="mb-8">
        <div class="inline-flex items-center gap-3 px-5 py-3 bg-white/5 backdrop-blur-md rounded-full border border-white/10 glass-glow">
          <!-- Google "G" logo -->
          <svg class="w-5 h-5 shrink-0" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
            <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
            <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/>
            <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
          </svg>
          <div class="w-px h-4 bg-white/20"></div>
          <!-- 5 stars -->
          <div class="flex items-center gap-0.5">
            <svg class="w-4 h-4 text-yellow-400" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
            <svg class="w-4 h-4 text-yellow-400" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
            <svg class="w-4 h-4 text-yellow-400" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
            <svg class="w-4 h-4 text-yellow-400" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
            <svg class="w-4 h-4 text-yellow-400" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
          </div>
          <div class="w-px h-4 bg-white/20"></div>
          <span class="text-sm font-semibold text-white/90 tracking-wide">Trusted by our customers</span>
        </div>
      </div>

      <h1>
        <span data-animate class="block text-5xl sm:text-6xl lg:text-7xl font-bold text-white leading-none tracking-tight" style="text-shadow: 0 2px 20px rgba(0,0,0,0.3);">{title}</span>
      </h1>

      <p data-animate class="mt-8 text-xl text-white/80 leading-relaxed">
        {subtitle}
      </p>

      <div data-motion class="flex flex-wrap gap-4 mt-10">
        <a href={ctaLink} class="px-8 py-4 bg-brand-600 hover:bg-brand-500 text-white font-semibold rounded-full transition-all inline-flex items-center gap-2 hover-shimmer active:scale-[0.97] hover:shadow-lg hover:shadow-brand-600/30">
          {ctaText}
          <Icon name="arrow-right" class="w-4 h-4" />
        </a>
        {secondaryText && secondaryLink && (
          <a href={secondaryLink} class="px-8 py-4 bg-white/10 backdrop-blur-sm text-white font-semibold rounded-full border border-white/30 hover:bg-white/20 transition-all inline-flex items-center gap-2 hover-lift active:scale-[0.97]">
            {secondaryText}
          </a>
        )}
      </div>

      <div data-motion class="mt-16 p-6 bg-white/10 backdrop-blur-md rounded-3xl border border-white/20 inline-block glass-glow">
        <div class="flex items-center gap-6">
          <div>
            <span class="text-white/60 text-sm">Years of Experience</span>
            <p class="text-white font-semibold">20+ Years</p>
          </div>
          <div class="w-px h-10 bg-white/20"></div>
          <div>
            <span class="text-white/60 text-sm">Availability</span>
            <p class="text-white font-semibold">24/7 Always Open</p>
          </div>
          <div class="w-px h-10 bg-white/20"></div>
          <div>
            <span class="text-white/60 text-sm">Quality</span>
            <p class="text-white font-semibold">100% Local & Fresh</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  // Cursor glow follows mouse
  const hero = document.querySelector('.hero-cursor-glow');
  if (hero) {
    hero.addEventListener('mousemove', (e) => {
      const rect = hero.getBoundingClientRect();
      const x = ((e.clientX - rect.left) / rect.width) * 100;
      const y = ((e.clientY - rect.top) / rect.height) * 100;
      hero.style.setProperty('--glow-x', x + '%');
      hero.style.setProperty('--glow-y', y + '%');
    });
  }
</script>
