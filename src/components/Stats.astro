---
const { items } = Astro.props;
---

<section class="py-16 bg-white border-y border-neutral-100">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-8">
      {items.map((item) => (
        <div data-motion class="text-center">
          <span class="text-3xl font-bold text-brand-600 block">{item.number}</span>
          <span class="text-neutral-500 text-sm">{item.label}</span>
        </div>
      ))}
    </div>
  </div>
</section>
