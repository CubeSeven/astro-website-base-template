---
import { Icon as AstroIcon } from 'astro-icon/components';

export interface Props {
  name: string;
  class?: string;
}

const { name, class: className = "w-5 h-5" } = Astro.props;

// Map old icon names to Lucide icon names
const iconMap: Record<string, string> = {
  'fish': 'lucide:fish',
  'fish-simple': 'lucide:fish',
  'octopus': 'lucide:shell',
  'shrimp': 'lucide:shell',
  'crab': 'lucide:shell',
  'lobster': 'lucide:shell',
  'squid': 'lucide:shell',
  'shell': 'lucide:shell',
  'anchor': 'lucide:anchor',
  'boat': 'lucide:ship',
  'yacht': 'lucide:ship',
  'wave': 'lucide:waves',
  'droplet': 'lucide:droplet',
  'thermometer-cold': 'lucide:thermometer',
  'snowflake': 'lucide:snowflake',
  'scale': 'lucide:scale',
  'weight': 'lucide:weight',
  'trophy': 'lucide:trophy',
  'medal': 'lucide:medal',
  'certificate': 'lucide:award',
  'knife': 'lucide:utensils-crossed',
  'cut': 'lucide:scissors',
  'grill': 'lucide:flame',
  'flame': 'lucide:flame',
  'utensils': 'lucide:utensils',
  'plate': 'lucide:plate',
  'olive': 'lucide:circle',
  'island': 'lucide:landmark',
  'map': 'lucide:map',
  'map-pin': 'lucide:map-pin',
  'truck': 'lucide:truck',
  'package': 'lucide:package',
  'clock': 'lucide:clock',
  'calendar': 'lucide:calendar',
  'star': 'lucide:star',
  'shield-check': 'lucide:shield-check',
  'check': 'lucide:check',
  'users': 'lucide:users',
  'phone': 'lucide:phone',
  'whatsapp': 'lucide:message-circle',
  'mail': 'lucide:mail',
  'location': 'lucide:map-pin',
  'arrow-right': 'lucide:arrow-right',
  'chevron-down': 'lucide:chevron-down',
  'menu': 'lucide:menu',
  'heart': 'lucide:heart',
  'eye': 'lucide:eye',
  'sparkles': 'lucide:sparkles',
  'sun': 'lucide:sun',
  'gift': 'lucide:gift',
  'home': 'lucide:home',
  'building': 'lucide:building',
  'store': 'lucide:store',
  'chart': 'lucide:bar-chart',
  'trending-up': 'lucide:trending-up',
  'badge-check': 'lucide:badge-check',
  'leaf': 'lucide:leaf',
  'refresh': 'lucide:refresh-cw',
  'zap': 'lucide:zap',
  'globe': 'lucide:globe',
  'clipboard': 'lucide:clipboard',
  'search': 'lucide:search',
  'info': 'lucide:info',
  'help-circle': 'lucide:help-circle',
  'truck-delivery': 'lucide:truck',
  'handshake': 'lucide:handshake',
  'restaurant': 'lucide:utensils',
  'instagram': 'lucide:instagram',
  'facebook': 'lucide:facebook',
  'close': 'lucide:x',
  'x': 'lucide:x',
  'menu-open': 'lucide:x',
};

const iconName = iconMap[name] || 'lucide:help-circle';
---

<AstroIcon name={iconName} class={className} />
