---
const { class: className, size = "md" } = Astro.props;

const sizes = {
  sm: "h-10",
  md: "h-14",
  lg: "h-20",
};
const heightClass = sizes[size] || sizes.md;
---

<div
  class="logo-wrapper inline-flex items-center justify-center bg-white rounded-xl px-3 flex-shrink-0"
  class:list={[heightClass, className]}
>
  <img
    src="/logo.svg"
    alt=""
    role="presentation"
    class="h-full w-auto max-w-none object-contain"
    loading="eager"
  />
</div>

<style>
  .logo-wrapper {
    width: auto;
  }
</style>
