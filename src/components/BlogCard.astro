---
import Icon from './Icon.astro';
import { SITE } from '../data/site.config';
import type { BlogPost } from '../data/content/blog';

export interface Props {
  post: BlogPost;
}

const { post } = Astro.props;
const postUrl = `${SITE.blog.path}/${post.slug}`;
---

<article class="bg-white rounded-3xl overflow-hidden shadow-sm hover:shadow-lg transition-all duration-300 hover-lift group flex flex-col">
  <a href={postUrl} class="block overflow-hidden aspect-[16/10]">
    <img
      src={post.image}
      alt={post.alt}
      class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
      loading="lazy"
      decoding="async"
    />
  </a>
  <div class="p-6 flex flex-col flex-1">
    <div class="flex items-center gap-3 text-xs text-neutral-500 mb-3">
      {post.category && (
        <span class="px-2.5 py-1 bg-brand-50 text-brand-700 font-medium rounded-full">
          {post.category}
        </span>
      )}
      <time datetime={post.date}>
        {new Date(post.date).toLocaleDateString("en-US", { year: "numeric", month: "short", day: "numeric" })}
      </time>
      {post.readingTime && (
        <>
          <span class="w-1 h-1 bg-neutral-300 rounded-full"></span>
          <span>{post.readingTime} min read</span>
        </>
      )}
    </div>
    <h2 class="text-lg font-bold text-neutral-900 mb-2 group-hover:text-brand-600 transition-colors">
      <a href={postUrl}>{post.title}</a>
    </h2>
    <p class="text-neutral-600 text-sm leading-relaxed mb-4 flex-1">
      {post.excerpt}
    </p>
    <a href={postUrl} class="inline-flex items-center gap-1.5 text-sm font-semibold text-brand-600 hover:text-brand-700 transition-colors mt-auto">
      Read More
      <Icon name="arrow-right" class="w-4 h-4" />
    </a>
  </div>
</article>
